# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_gateway
DB_USER=root
DB_PASSWORD=

# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
ELEVENLABS_API_KEY=...
REPLICATE_API_KEY=r8_...

# Gateway Config
DEFAULT_ROUTING_STRATEGY=weighted-load
ENABLE_STREAMING=true
ENABLE_USAGE_LOGGING=true

# CORS
CORS_ORIGIN=http://localhost:5173
